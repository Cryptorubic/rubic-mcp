# Rubic MCP Server — Environment Variables
# Copy this file to .env and uncomment/edit the values you need.

# --- Private key ---

# EVM private key (without 0x prefix).
# Without this, the server works in quote-only mode.
#PRIVATE_KEY=

# --- Transport ---

# Server transport mode: "stdio" (default, for CLI integrations) or "http"
#MCP_TRANSPORT=stdio

# HTTP server settings (only used when MCP_TRANSPORT=http)
#MCP_HOST=127.0.0.1
#MCP_PORT=3333

# --- API url ---

#RUBIC_API_BASE_URL=https://rubic-api-v2.rubic.exchange


# --- Timeout ---

#RUBIC_API_TIMEOUT_MS=60000
#MCP_TOOL_TIMEOUT_MS=60000
